{
	"info": {
		"_postman_id": "cart-checkout-collection",
		"name": "Talent Marketplace - Cart & Checkout",
		"description": "Complete cart and checkout API endpoints for testing",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Cart",
			"item": [
				{
					"name": "Get Cart Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/cart",
							"host": ["{{baseUrl}}"],
							"path": ["api", "cart"]
						}
					}
				},
				{
					"name": "Add to Cart",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/cart",
							"host": ["{{baseUrl}}"],
							"path": ["api", "cart"]
						}
					}
				},
				{
					"name": "Remove from Cart",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/cart?productId={{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "cart"],
							"query": [
								{
									"key": "productId",
									"value": "{{productId}}"
								}
							]
						}
					}
				},
				{
					"name": "Clear Cart",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/cart/clear",
							"host": ["{{baseUrl}}"],
							"path": ["api", "cart", "clear"]
						}
					}
				}
			]
		},
		{
			"name": "Checkout",
			"item": [
				{
					"name": "Create Order",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"items\": [\n    {\n      \"id\": \"{{productId}}\",\n      \"productId\": \"{{productId}}\",\n      \"title\": \"Product Name\",\n      \"price\": 5000,\n      \"quantity\": 2\n    }\n  ],\n  \"phoneNumber\": \"254712345678\",\n  \"shippingAddress\": \"Digital delivery\",\n  \"useEscrow\": false\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/checkout",
							"host": ["{{baseUrl}}"],
							"path": ["api", "checkout"]
						}
					}
				}
			]
		},
		{
			"name": "Escrow",
			"item": [
				{
					"name": "Create Escrow Transaction",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"sellerId\": \"{{sellerId}}\",\n  \"amount\": 10000,\n  \"currency\": \"KES\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/escrow",
							"host": ["{{baseUrl}}"],
							"path": ["api", "escrow"]
						}
					}
				},
				{
					"name": "Get User Escrow Transactions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/escrow",
							"host": ["{{baseUrl}}"],
							"path": ["api", "escrow"]
						}
					}
				},
				{
					"name": "Approve Escrow",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"approve\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/escrow/{{escrowId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "escrow", "{{escrowId}}"]
						}
					}
				},
				{
					"name": "Complete Escrow",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"complete\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/escrow/{{escrowId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "escrow", "{{escrowId}}"]
						}
					}
				},
				{
					"name": "Reject Escrow",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"reject\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/escrow/{{escrowId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "escrow", "{{escrowId}}"]
						}
					}
				},
				{
					"name": "Refund Escrow",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"action\": \"refund\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/escrow/{{escrowId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "escrow", "{{escrowId}}"]
						}
					}
				}
			]
		},
		{
			"name": "Payment",
			"item": [
				{
					"name": "M-Pesa STK Push",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"254712345678\",\n  \"amount\": 10000,\n  \"orderId\": \"{{orderId}}\",\n  \"description\": \"Order #12345\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/mpesa/stkpush",
							"host": ["{{baseUrl}}"],
							"path": ["api", "mpesa", "stkpush"]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "productId",
			"value": "your-product-id",
			"type": "string"
		},
		{
			"key": "orderId",
			"value": "your-order-id",
			"type": "string"
		},
		{
			"key": "sellerId",
			"value": "your-seller-id",
			"type": "string"
		},
		{
			"key": "escrowId",
			"value": "your-escrow-id",
			"type": "string"
		}
	]
}
