# M-Pesa Daraja API Configuration
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here

# M-Pesa Sandbox Credentials
MPESA_SHORTCODE=your_shortcode_here
MPESA_PASSKEY=your_passkey_here

# M-Pesa API URLs (Sandbox)
MPESA_AUTH_URL=https://sandbox.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials
MPESA_STK_URL=https://sandbox.safaricom.co.ke/mpesa/stkpush/v1/processrequest

# Your app URL (use ngrok for local development)
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL="your_database_url_here"